# ─────────────────────────────────────────────────────────────────────────────
# OpsPilot Frontend — Environment Variables
# Copy to frontend/.env (gitignored) and adjust for your environment.
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the OpsPilot backend API (REST + SSE stream).
# Local dev default is http://localhost:8000 — override for deployment.
VITE_API_BASE_URL=http://localhost:8000
