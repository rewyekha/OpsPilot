# ─────────────────────────────────────────────────────────────────────────────
# OpsPilot Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Execution mode (provider selection) ──────────────────────────────────────
# mock    = deterministic mock provider (DEFAULT; no Azure credentials needed)
# foundry = Azure AI Foundry (fails if FOUNDRY_ENDPOINT is missing)
# auto    = Foundry when FOUNDRY_ENDPOINT is set, otherwise mock
EXECUTION_MODE=mock

# ── Azure AI Foundry provider ─────────────────────────────────────────────────
# Endpoint format: https://<resource-name>.openai.azure.com/ (or Foundry inference URL)
FOUNDRY_ENDPOINT=
# Leave FOUNDRY_API_KEY empty to use managed identity (DefaultAzureCredential)
FOUNDRY_API_KEY=
FOUNDRY_API_VERSION=2024-08-01-preview

# ── Azure OpenAI (legacy structured-output path used by the existing agents) ──
# Endpoint format: https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# API key auth (leave empty to use DefaultAzureCredential / managed identity)
AZURE_OPENAI_API_KEY=

# API version — use 2024-08-01-preview or later for structured output support
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Model deployment names (set in Azure AI Foundry / AOAI Studio) ────────────
# Specialist agents: MetricsAgent, LogsAgent, DeploymentAgent
SPECIALIST_MODEL_DEPLOYMENT=gpt-4o-mini

# Commander agents: CorrelationAgent, RootCauseAgent, RecommendationAgent, CommanderAgent
COMMANDER_MODEL_DEPLOYMENT=gpt-4o

# Deep reasoning (optional — used when agent confidence < 0.7)
REASONING_MODEL_DEPLOYMENT=o3

# ── Azure AI Foundry project (optional — enables tracing in Foundry portal) ──
# Format: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.MachineLearningServices/workspaces/<project>
AZURE_AI_FOUNDRY_PROJECT_NAME=
AZURE_AI_FOUNDRY_RESOURCE_GROUP=
AZURE_SUBSCRIPTION_ID=

# ── Azure Cosmos DB (optional — enables investigation persistence) ────────────
# Endpoint format: https://<account>.documents.azure.com:443/
COSMOS_DB_ENDPOINT=
COSMOS_DB_DATABASE=opspilot
COSMOS_DB_INCIDENTS_CONTAINER=incidents

# ── Azure AI Search (optional — enables episodic memory / runbook retrieval) ──
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=incident-history

# ── Application settings ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# CORS origins (comma-separated list of allowed frontend origins)
API_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Local development ─────────────────────────────────────────────────────────
# Redis is not required locally; only needed for distributed deployments
REDIS_URL=redis://localhost:6379/0
