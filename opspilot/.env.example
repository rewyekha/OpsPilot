# ─────────────────────────────────────────────────────────────────────────────
# Root-level environment variables (never commit real values)
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure AI Foundry / OpenAI ────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<set-via-key-vault-in-production>
AZURE_OPENAI_API_VERSION=2024-08-01-preview

AZURE_AI_FOUNDRY_PROJECT_NAME=opspilot-foundry
AZURE_AI_FOUNDRY_RESOURCE_GROUP=rg-opspilot

# Deployment names (configure in Azure AI Foundry portal)
COMMANDER_MODEL_DEPLOYMENT=gpt-4o
SPECIALIST_MODEL_DEPLOYMENT=gpt-4o-mini
REASONING_MODEL_DEPLOYMENT=o3

# ── Azure Infrastructure ─────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=rg-opspilot
AZURE_LOCATION=eastus2

# ── Azure Cosmos DB ──────────────────────────────────────────────────────────
COSMOS_DB_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_DB_DATABASE=opspilot
COSMOS_DB_KEY=<set-via-managed-identity-in-production>

# ── Azure AI Search ──────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-service>.search.windows.net
AZURE_SEARCH_KEY=<set-via-managed-identity-in-production>
AZURE_SEARCH_INDEX_INCIDENTS=past-incidents
AZURE_SEARCH_INDEX_RUNBOOKS=runbooks

# ── Azure Application Insights ───────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;...

# ── Backend API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,https://<your-aca-domain>
LOG_LEVEL=INFO

# ── Authentication (Azure Entra ID) ──────────────────────────────────────────
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-app-registration-client-id>

# ── Feature Flags ────────────────────────────────────────────────────────────
USE_MOCK_TOOLS=true          # true = use JSON fixtures; false = call real APIs
ENABLE_DEEP_REASONING=false  # enables o3 fallback when confidence < 0.7
ENABLE_ACTION_EXECUTION=false  # enables one-click remediation actions
