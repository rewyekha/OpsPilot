# ─────────────────────────────────────────────────────────────────────────────
# OpsPilot — environment configuration
# Copy to .env:   cp .env.example .env
#
# The defaults below run OpsPilot in ZERO-CREDENTIAL mock mode — no Azure account,
# no API keys, no deployed workloads. Just `docker compose up` (or the local dev
# commands in the README) and click "New Investigation" on the dashboard to see a
# full multi-agent investigation with a confidence-scored root cause and ranked
# remediations. This is the recommended way to evaluate OpsPilot.
# ─────────────────────────────────────────────────────────────────────────────

# ── Run mode (leave as-is for the zero-credential demo) ──────────────────────
# mock    = deterministic agents, no Azure/Foundry calls   (DEFAULT — judge mode)
# foundry = live Azure AI Foundry inference (requires FOUNDRY_ENDPOINT below)
EXECUTION_MODE=mock

# synthetic = no telemetry backend needed                  (DEFAULT — judge mode)
# azure     = live Application Insights / Log Analytics (requires workspace id)
TELEMETRY_MODE=synthetic

# ── Backend API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
API_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — live Azure AI Foundry  (only used when EXECUTION_MODE=foundry)
# ═════════════════════════════════════════════════════════════════════════════
# FOUNDRY_ENDPOINT=https://<your-resource>.openai.azure.com/
# FOUNDRY_API_KEY=                       # leave empty to use managed identity
# FOUNDRY_API_VERSION=2025-04-01-preview
# COMMANDER_MODEL_DEPLOYMENT=gpt-4o
# SPECIALIST_MODEL_DEPLOYMENT=gpt-4o-mini
# REASONING_MODEL_DEPLOYMENT=o4-mini

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — live Azure telemetry  (only used when TELEMETRY_MODE=azure)
# ═════════════════════════════════════════════════════════════════════════════
# Get the workspace id: az monitor log-analytics workspace list -g rg-opspilot \
#   --query "[0].customerId" -o tsv
# AZURE_LOG_ANALYTICS_WORKSPACE_ID=
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL — demo scenarios  (live Azure only; needs az CLI + a deployed workload)
# ═════════════════════════════════════════════════════════════════════════════
# DEMO_MODE_ENABLED=false
# DEMO_RESOURCE_GROUP=rg-opspilot
# DEMO_APP_NAME=album-api
