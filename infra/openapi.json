etrics → logs → deployment → time_machine → root_cause → [deep_reasoning] → recommendation) as a background task. Real agent execution; progress is emitted over the incident's SSE stream. No-op if a run is already in flight.","operationId":"investigate_api_incidents__incident_id__investigate_post","parameters":[{"name":"incident_id","in":"path","required":true,"schema":{"type":"string","title":"Incident Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/InvestigateResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/incidents/{incident_id}/deep-reasoning":{"post":{"tags":["investigations"],"summary":"Run deep reasoning (o4-mini) over the current findings","description":"Sends the specialist findings + current root cause to the DeepReasoningAgent (REASONING/o4-mini role) and returns a refined root cause with a chain-of-thought reasoning trace. Real model execution in foundry mode; emits SSE progress events.","operationId":"deep_reasoning_api_incidents__incident_id__deep_reasoning_post","parameters":[{"name":"incident_id","in":"path","required":true,"schema":{"type":"string","title":"Incident Id"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeepReasoningRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DeepReasoningResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/investigations":{"get":{"tags":["insights"],"summary":"Completed investigation history","operationId":"list_investigations_api_investigations_get","parameters":[{"name":"incident_id","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Incident Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/InvestigationRecord"},"title":"Response List Investigations Api Investigations Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/investigations/latest":{"get":{"tags":["insights"],"summary":"Most recent investigation record","operationId":"latest_investigation_api_investigations_latest_get","parameters":[{"name":"incident_id","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Incident Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"anyOf":[{"$ref":"#/components/schemas/InvestigationRecord"},{"type":"null"}],"title":"Response Latest Investigation Api Investigations Latest Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/analytics":{"get":{"tags":["insights"],"summary":"Analytics computed from stored investigations","operationId":"analytics_api_analytics_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Analytics Api Analytics Get"}}}}}}},"/api/agents/stats":{"get":{"tags":["insights"],"summary":"Per-agent execution stats from stored investigations","operationId":"agent_stats_api_agents_stats_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"items":{"additionalProperties":true,"type":"object"},"type":"array","title":"Response Agent Stats Api Agents Stats Get"}}}}}}},"/api/system/health":{"get":{"tags":["system"],"summary":"Azure AI Foundry configuration health","description":"Returns current Foundry configuration status, model deployment n